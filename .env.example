# Local: npm start — copy to .env and adjust values
# Server deploy: docker compose; use HOST=0.0.0.0 and DB_HOST=192.168.3.12

PORT=5006
HOST=127.0.0.1

DB_TYPE=mysql
DB_HOST=192.168.3.12
DB_PORT=3306
DB_USER=unit1_app
DB_PASSWORD=your-password-here
DB_NAME=data_entry_unit1

SAP_SERVICE_LAYER_URL=https://192.168.3.6:50000/b1s/v1
SAP_COMPANY_DB=VKFINALLIVE
SAP_USERNAME=manager
SAP_PASSWORD=your-sap-password
SAP_RETRY=3
SAP_SSL_VERIFY=false

SAP_FG_ITEMS_GROUP=100
SAP_COMPONENT_ITEMS_GROUP=115
SAP_UOM_CODE=KGS
SAP_UOM_GROUP_ENTRY=-1
SAP_UOM_KGS_ENTRY=1
SAP_PACK_UOM_CODE=Roll
SAP_MATERIAL_TYPE_INVERT_UI=true
SAP_MATERIAL_TYPE_FG=mt_RawMaterial
SAP_MATERIAL_TYPE_COMPONENT=mt_FinishedGoods
SAP_HSN_CODE=3921.90.94
SAP_CHAPTER_ID=72
SAP_ITEM_TAX_RATE=18
SAP_GST_TAX_CATEGORY=gtc_Regular
SAP_PRICING_UNIT=-1
UNIT1_DEFAULT_UOM=KGS

SAP_BOM_PROCESS_ITEM_UOM=KGS

SECRET_KEY=change-me
